NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --h1-size: 1.3em; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=theme-dark mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars is-floating-nav auto-full-screen show-ribbon show-view-header css-settings-manager callouts-default trim-cols active-line-on checkbox-circle pdf-seamless-on pdf-invert-dark pdf-blend-light metadata-add-property-off metadata-dividers sidebar-tabs-underline tab-names-off vault-profile-top hide-help ribbon-hidden maximize-tables-off row-lines col-lines table-lines row-alt col-alt table-tabular table-numbers tabs-default tab-stack-top minimal-tab-title-hover default minimal-line-nums minimal-readable-off code-styler code-styler-style-inline code-styler-gutter-highlight code-styler-active-line-highlight minimal-theme minimal-light minimal-things-light minimal-dark minimal-things-dark colorful-headings colorful-frame colorful-active links-int-on links-ext-on full-width-media img-grid minimal-folding chart-max table-max img-max iframe-max map-max oz-show-all-num is-focused
USE_FULL_RESOLUTION_IMAGES=false
THEME=https://raw.githubusercontent.com/tazpellegrini/abyssalobsidian/HEAD/theme.css
BASE_THEME=light
dgHomeLink=true
dgPassFrontmatter=false
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
